{
  "headers": [
    {
      "source": "/sites/:path*.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=3600"
        }
      ]
    },
    {
      "source": "/sites/:path*.(css|js|svg|png|jpg|jpeg|webp|woff2|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800, immutable"
        }
      ]
    },
    {
      "source": "/sites/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
